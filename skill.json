{
  "name": "link2vs",
  "version": "26.2.0-rc4",
  "description": "Connect AI Agent to Visual Studio 2026/2022 and VS Code via Unified MCP Protocol (UniversalVSMCP). Native .NET runtime with unified IIdeAdapter architecture, multi-IDE support, security framework, and hybrid VS Code Extension architecture.",
  "author": "StarsailsClover",
  "license": "MIT",
  "repository": "https://github.com/StarsailsClover/Link2VS.skill",
  "tags": ["visual-studio", "vscode", "mcp", "ide", "automation", "dotnet", "csharp", "vs2026", "ai-agent", "hybrid-architecture"],
  "entry_point": "uvm_bridge",
  "capabilities": [
    "read_vs_solution",
    "execute_build",
    "debug_control",
    "file_operations",
    "project_management",
    "create_workspace",
    "diagnostic_tools"
  ],
  "mcp_config": {
    "preferred_runtime": "dotnet",
    "description": "Configuration for AI Agent to connect to VS via UniversalVSMCP. Single installation method via NuGet.",
    "single_install_method": {
      "method": "nuget",
      "command": "dotnet tool install -g UniversalVSMCP",
      "run_command": "universal-vsmcp --stdio",
      "verify_command": "universal-vsmcp --help",
      "nuget_url": "https://www.nuget.org/packages/UniversalVSMCP/"
    },
    "configs": {
      "dotnet_tool_stdio": {
        "runtime": "dotnet",
        "transport": "stdio",
        "command": "dotnet",
        "args": [
          "tool",
          "run",
          "--global",
          "universal-vsmcp",
          "--",
          "--stdio"
        ],
        "env": {
          "VS_AUTO_DETECT": "true"
        },
        "description": "Primary configuration: NuGet global tool with stdio transport"
      },
      "localhost_dev": {
        "runtime": "dotnet",
        "transport": "stdio",
        "command": "dotnet",
        "args": [
          "run",
          "--project",
          "${workspaceFolder}",
          "--",
          "--stdio"
        ],
        "env": {
          "VS_AUTO_DETECT": "true"
        },
        "url": "http://localhost:6277/sse",
        "description": "Local development configuration with localhost URL"
      },
      "source_install": {
        "runtime": "dotnet",
        "transport": "stdio",
        "command": "dotnet",
        "args": [
          "run",
          "--project",
          "C:\\path\\to\\UniversalVSMCP\\src\\UniversalVSMCP\\UniversalVSMCP.csproj",
          "--",
          "--stdio"
        ],
        "env": {
          "VS_AUTO_DETECT": "true"
        },
        "description": "Source install for development (use nuget method instead)"
      }
    },
    "vs2026_config": {
      "description": "VS 2026 configuration",
      "gui_steps": [
        "1. Open Visual Studio 2026",
        "2. Go to Tools > Options > Environment > Extensions",
        "3. Check 'Edit user settings as JSON'",
        "4. Paste the mcpServers configuration from dotnet_tool_stdio",
        "5. Save and restart VS if needed"
      ],
      "json_template": {
        "mcpServers": {
          "universal-vsmcp": {
            "command": "dotnet",
            "args": [
              "tool",
              "run",
              "--global",
              "universal-vsmcp",
              "--",
              "--stdio"
            ],
            "env": {
              "VS_AUTO_DETECT": "true"
            }
          }
        }
      }
    },
    "claude_desktop_config": {
      "description": "Configuration for Claude Desktop / Cursor / Cline - uses dynamic path",
      "config": {
        "mcpServers": {
          "vsmcp": {
            "command": "dotnet",
            "args": ["tool", "run", "--global", "universal-vsmcp", "--", "--stdio"],
            "env": {
              "VS_AUTO_DETECT": "true"
            }
          }
        }
      },
      "note": "Path is relative to dotnet global tools folder, no hardcoded absolute paths"
    }
  },
  "skills": {
    "installation": {
      "prerequisites": [
        ".NET 8.0 SDK or later",
        "Visual Studio 2026 (18.0) or VS 2022 (17.14+)",
        "Windows 10 or later"
      ],
      "single_method": {
        "name": "NuGet Global Tool",
        "steps": [
          "1. dotnet tool install -g UniversalVSMCP",
          "2. universal-vsmcp --stdio",
          "3. Verify: universal-vsmcp --help"
        ]
      },
      "commands": {
        "install": "dotnet tool install -g UniversalVSMCP",
        "update": "dotnet tool update -g UniversalVSMCP",
        "uninstall": "dotnet tool uninstall -g UniversalVSMCP",
        "run": "universal-vsmcp --stdio",
        "run_with_log": "universal-vsmcp --stdio --log-file uv.log",
        "verify": "universal-vsmcp --help",
        "list_tools": "dotnet tool list -g"
      }
    },
    "diagnostics": {
      "description": "Built-in diagnostic tools for troubleshooting",
      "tools": [
        "health_check - Verify server and VS connection",
        "get_server_info - Get server capabilities",
        "get_diagnostic_logs - Get recent log entries"
      ],
      "commands": {
        "check_connection": "Use health_check MCP tool",
        "view_logs": "universal-vsmcp --stdio --log-file uv.log",
        "check_vs": "Ensure VS is running with solution open"
      }
    }
  },
  "metadata": {
    "mcp_registry_compatible": true,
    "server_json_spec": "https://github.com/docker/mcp-community-registry/blob/main/docs/reference/server-json/generic-server-json.md",
    "vs_compatibility": {
      "vs2026": "18.0 (primary)",
      "vs2022": "17.14+ (secondary)"
    },
    "nuget_package": {
      "id": "UniversalVSMCP",
      "version": "1.0.0",
      "url": "https://www.nuget.org/packages/UniversalVSMCP/"
    },
    "runtime": {
      "preferred": "dotnet",
      "supported": ["dotnet"]
    },
    "tool_count": 30,
    "transports": ["stdio", "sse"],
    "localhost_support": true
  }
}
